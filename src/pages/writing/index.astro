---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";

const writing = (await getCollection("writing", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf(),
);

const [featuredPost, ...otherPosts] = writing;

const navLinks = [
  { text: "Home", href: "/" },
  { text: "Writing", href: "/writing" },
];
---

<Layout
  title="Writing | Zoárd Manó Csoltai"
  description="Technical writing, case studies, and notes from Zoárd Manó Csoltai."
  navLinks={navLinks}
  mainClass="relative z-10 mx-auto max-w-5xl px-5 pt-28 md:px-6 md:pt-32 lg:px-8 lg:pt-0 lg:pr-28"
>
  <section class="writing-shell py-16 md:py-24">
    <div class="mb-18 grid gap-10 lg:grid-cols-[minmax(0,1.2fr)_minmax(18rem,0.8fr)] lg:items-end">
      <div class="max-w-4xl">
        <p class="mb-4 text-sm font-medium tracking-[0.2em] text-primary uppercase">
          Writing
        </p>
        <h1 class="mb-6 font-serif text-5xl font-bold tracking-tightest text-white md:text-7xl">
          Notes, systems, and technical writeups.
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-neutral md:text-xl">
          A native home for longer-form case studies and technical writing,
          starting with the systems work that used to live in Notion.
        </p>
      </div>

      <div class="rounded-3xl border border-white/8 bg-[#121a23]/72 p-6 backdrop-blur-sm">
        <p class="mb-3 text-sm font-medium tracking-[0.2em] text-primary uppercase">
          At a glance
        </p>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <p class="font-serif text-4xl font-bold text-white">{writing.length}</p>
            <p class="text-sm text-neutral">Published pieces</p>
          </div>
          <div>
            <p class="font-serif text-4xl font-bold text-white">
              {new Set(writing.flatMap((post) => post.data.tags)).size}
            </p>
            <p class="text-sm text-neutral">Tracked topics</p>
          </div>
        </div>
      </div>
    </div>

    {
      featuredPost && (
        <article class="mb-10 rounded-[2rem] border border-white/10 bg-[linear-gradient(180deg,rgba(18,26,35,0.95),rgba(12,18,26,0.92))] p-8 shadow-[0_30px_80px_rgba(0,0,0,0.28)] backdrop-blur-sm md:p-10">
          <p class="mb-4 text-sm font-medium tracking-[0.2em] text-primary uppercase">
            Featured article
          </p>

          <div class="mb-5 flex flex-wrap items-center gap-3 text-sm text-neutral">
            <time datetime={featuredPost.data.published.toISOString()}>
              {featuredPost.data.published.toLocaleDateString("en-GB", {
                day: "numeric",
                month: "long",
                year: "numeric",
              })}
            </time>
            {featuredPost.data.tags.map((tag) => (
              <span class="rounded-full border border-white/10 px-3 py-1 text-xs uppercase tracking-[0.16em] text-white/70">
                {tag}
              </span>
            ))}
          </div>

          <h2 class="mb-4 max-w-4xl font-serif text-4xl font-semibold tracking-tight text-white md:text-6xl">
            <a class="hover:text-primary" href={`/writing/${featuredPost.slug}`}>
              {featuredPost.data.title}
            </a>
          </h2>

          <p class="mb-8 max-w-3xl text-lg leading-8 text-neutral md:text-xl">
            {featuredPost.data.description}
          </p>

          <a
            class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/4 px-5 py-3 text-sm font-medium text-primary transition-colors hover:border-white/20 hover:text-white"
            href={`/writing/${featuredPost.slug}`}
          >
            Read article
            <span aria-hidden="true">→</span>
          </a>
        </article>
      )
    }

    {
      otherPosts.length > 0 && (
        <>
          <div class="mb-8 mt-16 flex items-center justify-between gap-4">
            <h2 class="font-serif text-3xl font-bold tracking-tight text-white md:text-4xl">
              More writing
            </h2>
          </div>

          <div class="grid gap-6 md:grid-cols-2">
            {otherPosts.map((post) => (
              <article class="rounded-3xl border border-white/8 bg-[#121a23]/72 p-6 backdrop-blur-sm transition-transform duration-300 hover:-translate-y-1">
                <div class="mb-4 flex flex-wrap items-center gap-3 text-sm text-neutral">
                  <time datetime={post.data.published.toISOString()}>
                    {post.data.published.toLocaleDateString("en-GB", {
                      day: "numeric",
                      month: "long",
                      year: "numeric",
                    })}
                  </time>
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="rounded-full border border-white/10 px-3 py-1 text-[11px] uppercase tracking-[0.16em] text-white/70">
                      {tag}
                    </span>
                  ))}
                </div>

                <h3 class="mb-3 font-serif text-3xl font-semibold text-white">
                  <a class="hover:text-primary" href={`/writing/${post.slug}`}>
                    {post.data.title}
                  </a>
                </h3>

                <p class="mb-6 text-base leading-8 text-neutral">
                  {post.data.description}
                </p>

                <a
                  class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-white"
                  href={`/writing/${post.slug}`}
                >
                  Read article
                  <span aria-hidden="true">→</span>
                </a>
              </article>
            ))}
          </div>
        </>
      )
    }
  </section>
</Layout>

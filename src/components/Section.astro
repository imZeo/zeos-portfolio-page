---
interface Props {
  text: string;
  href: string;
}

const { text, href } = Astro.props;
---

<section id={href} class="py-24">
  <p class="mb-3 text-sm font-medium tracking-[0.2em] text-primary uppercase">
    {text}
  </p>
  <h2
    class="mb-12 font-serif text-4xl font-bold tracking-tighter text-white md:text-5xl"
  >
    {text}
  </h2>
  <slot />
</section>

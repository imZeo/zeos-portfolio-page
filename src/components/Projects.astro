---
import Section from "./Section.astro";
import type { ProjectProps } from "@types";

interface Props {
  projects: ProjectProps[];
}

const { projects } = Astro.props;
---

<Section text="Selected Work" href="projects">
  <div class="space-y-6">
    {
      projects.map(
        ({ name, summary, details = [], linkPreview, linkSource, linkLabel = "Read More" }) => (
        <article class="rounded-2xl border border-neutral/20 bg-[#121a23] p-6">
          <h3 class="mb-3 font-serif text-3xl font-medium text-primary">
            {name}
          </h3>
          <p class="mb-6 text-base text-neutral">{summary}</p>

          {
            details.length > 0 && (
              <ul class="mb-6 list-none">
                {details.map((detail) => (
                  <li class="relative mb-3 pl-8 text-base text-neutral before:absolute before:top-1 before:left-0 before:content-[url(/check.svg)]">
                    {detail}
                  </li>
                ))}
              </ul>
            )
          }

          {(linkSource || linkPreview) && (
            <div class="flex flex-wrap gap-5 text-white">
              {linkSource && (
                <a
                  href={linkSource}
                  target={linkSource.startsWith("http") ? "_blank" : undefined}
                  class="after:relative after:bottom-[-5px] after:content-[url(/external.svg)] hover:underline"
                >
                  {linkLabel}
                </a>
              )}
              {linkPreview && (
                <a
                  href={linkPreview}
                  target={linkPreview.startsWith("http") ? "_blank" : undefined}
                  class="after:relative after:bottom-[-5px] after:content-[url(/external.svg)] hover:underline"
                >
                  Preview
                </a>
              )}
            </div>
          )}
        </article>
      ),
      )
    }
  </div>
</Section>

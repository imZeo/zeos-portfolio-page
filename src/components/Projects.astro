---
import Section from "./Section.astro";
import type { ProjectProps } from "@types";

interface Props {
  projects: ProjectProps[];
}

const { projects } = Astro.props;
---

<Section text="Selected Work" href="projects">
  <div class="space-y-6">
    {
      projects.map(
        ({ name, summary, details = [], linkPreview, linkSource, linkLabel = "Read More" }) => (
        <article class="surface-panel p-6 md:p-7">
          <h3 class="mb-3 font-serif text-3xl font-medium text-primary">
            {name}
          </h3>
          <p class="mb-6 text-base text-neutral">{summary}</p>

          {
            details.length > 0 && (
              <ul class="mb-6 list-none">
                {details.map((detail) => (
                  <li class="list-marker relative mb-3 pl-8 text-base text-neutral">
                    {detail}
                  </li>
                ))}
              </ul>
            )
          }

          {(linkSource || linkPreview) && (
            <div class="flex flex-wrap gap-5 text-white">
              {linkSource && (
                <a
                  href={linkSource}
                  target={linkSource.startsWith("http") ? "_blank" : undefined}
                  class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-white"
                >
                  {linkLabel}
                  <span aria-hidden="true">→</span>
                </a>
              )}
              {linkPreview && (
                <a
                  href={linkPreview}
                  target={linkPreview.startsWith("http") ? "_blank" : undefined}
                  class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-white"
                >
                  Preview
                  <span aria-hidden="true">→</span>
                </a>
              )}
            </div>
          )}
        </article>
      ),
      )
    }
  </div>
</Section>

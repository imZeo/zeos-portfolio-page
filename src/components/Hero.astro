---
import type { HeroProps } from "@types";
import { SITE_CONFIG } from "@config";
type Props = HeroProps;

const {
  name,
  specialty,
  summary,
  email,
  secondaryLinks = [],
  highlights = [],
} = Astro.props;

const iconClass = "h-[1.05rem] w-[1.05rem]";
---

<section
  class="py-16 md:flex md:min-h-[calc(100vh-4.5rem)] md:items-center md:py-6"
  id="hero"
>
  <div class="max-w-xl">
    <div class="mb-10">
      <div class="hero-mark">
        <div class="hero-mark__halo"></div>
        <div class="hero-mark__frame">
          <img
            class="hero-mark__image"
            src={SITE_CONFIG.siteLogo}
            alt={`${name} logo`}
            loading="eager"
          />
        </div>
      </div>
    </div>

    <h1
      class="mb-4 max-w-lg font-serif text-5xl font-bold tracking-tightest text-white sm:text-6xl md:text-[clamp(3rem,4vw,4.5rem)] md:leading-[0.94]"
    >
      {name}
    </h1>

    <p
      class="mb-6 max-w-md font-serif text-2xl leading-[1.02] font-bold tracking-tighter text-primary sm:text-3xl md:text-[clamp(1.75rem,2.3vw,2.65rem)]"
    >
      {specialty}
    </p>

    <p class="mb-9 max-w-md text-[1rem] font-normal leading-8 text-neutral md:text-[1.05rem]">
      {summary}
    </p>

    <div class="mb-10 flex flex-wrap items-center gap-3">
      <a
        class="cta-button cta-button--primary inline-flex items-center gap-2 rounded-full px-7 py-3.5 text-sm leading-5 font-medium text-[#fff]"
        data-cta-button
        href={`mailto:${email}`}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          class={iconClass}
          aria-hidden="true"
        >
          <path d="M4 6h16v12H4z"></path>
          <path d="m4 7 8 6 8-6"></path>
        </svg>
        Get in Touch
      </a
      >

      {
        secondaryLinks.map((link) => (
          <a
            class="cta-button cta-button--secondary inline-flex items-center gap-2 rounded-full px-5 py-3 text-sm font-medium text-white/80"
            data-cta-button
            href={link.href}
            target={link.href.startsWith("http") ? "_blank" : undefined}
          >
            {
              link.text === "LinkedIn" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class={iconClass}
                  aria-hidden="true"
                >
                  <path d="M6.94 8.5H3.56V20h3.38V8.5Zm.22-3.56c0-1.02-.77-1.84-1.92-1.84-1.15 0-1.9.82-1.9 1.84 0 1 .73 1.84 1.86 1.84h.02c1.17 0 1.94-.84 1.94-1.84ZM20.44 13.02c0-3.48-1.86-5.1-4.34-5.1-2 0-2.9 1.1-3.4 1.88V8.5H9.33c.04.86 0 11.5 0 11.5h3.37v-6.42c0-.34.02-.68.13-.92.27-.68.88-1.38 1.9-1.38 1.34 0 1.88 1.02 1.88 2.52V20H20v-6.98Z" />
                </svg>
              )
            }
            {link.text}
          </a>
        ))
      }
    </div>

    {
      highlights.length > 0 && (
        <div class="flex flex-wrap gap-2.5">
          {highlights.map((highlight) => (
            <span class="rounded-full border border-white/10 bg-[#121a23]/72 px-3.5 py-2 text-[11px] font-medium tracking-[0.16em] text-white/70 uppercase backdrop-blur-sm">
              {highlight}
            </span>
          ))}
        </div>
      )
    }
  </div>
</section>

<script>
  const ctaButtons = document.querySelectorAll("[data-cta-button]");

  ctaButtons.forEach((button) => {
    if (!(button instanceof HTMLElement)) return;

    const handleMove = (event: PointerEvent) => {
      const rect = button.getBoundingClientRect();
      const x = event.clientX - rect.left;
      const y = event.clientY - rect.top;

      button.style.setProperty("--cta-x", `${x}px`);
      button.style.setProperty("--cta-y", `${y}px`);
    };

    const handleLeave = () => {
      button.style.removeProperty("--cta-x");
      button.style.removeProperty("--cta-y");
    };

    button.addEventListener("pointermove", handleMove);
    button.addEventListener("pointerleave", handleLeave);

    document.addEventListener(
      "astro:before-swap",
      () => {
        button.removeEventListener("pointermove", handleMove);
        button.removeEventListener("pointerleave", handleLeave);
      },
      { once: true },
    );
  });
</script>

---
import Menu from "@icons/Menu.astro";
import type { HeaderProps } from "@types";

type Props = HeaderProps;

const { navLinks } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header class="pointer-events-none fixed inset-x-0 top-0 z-50 animate-slide-in px-4 py-4 lg:inset-auto lg:top-1/2 lg:right-6 lg:px-0 lg:py-0">
  <div class="pointer-events-auto mx-auto flex max-w-6xl items-center justify-between rounded-[1.6rem] border border-white/8 bg-[#0e141b]/72 px-4 py-3 shadow-[0_20px_50px_rgba(0,0,0,0.22)] backdrop-blur-xl lg:mx-0 lg:w-auto lg:flex-col lg:justify-start lg:rounded-[2rem] lg:px-3 lg:py-3">
    <a
      href="/"
      class="text-sm font-semibold tracking-[0.24em] text-white/70 uppercase lg:hidden"
      aria-label="Home link"
    >
      Menu
    </a>

    <button
      type="button"
      id="menu-button"
      class="px-1.5 text-neutral lg:hidden"
      aria-expanded="false"
      aria-controls="main-menu"
    >
      <Menu />
    </button>

    <nav
      class="absolute top-[calc(100%+0.85rem)] left-0 right-0 hidden rounded-[1.4rem] border border-white/10 bg-[#0e141b]/92 px-3 py-3 text-neutral shadow-[0_20px_60px_rgba(0,0,0,0.35)] backdrop-blur-xl lg:static lg:block lg:w-auto lg:border-0 lg:bg-transparent lg:p-0 lg:shadow-none lg:backdrop-blur-0"
      id="main-menu"
    >
      <ul class="grid gap-1 lg:gap-2">
        {
          navLinks.map((link) => (
            <li class="relative">
              {
                (() => {
                  const isAnchor = link.href.startsWith("#");
                  const isActive = isAnchor
                    ? false
                    : currentPath === link.href ||
                      currentPath.startsWith(`${link.href}/`);

                  return (
                    <a
                      class={`nav-item block rounded-xl px-4 py-3 text-sm font-medium transition-all duration-300 hover:text-white lg:min-w-[7.25rem] lg:px-3 lg:text-center ${
                        isActive
                          ? "is-active bg-white/8 text-white ring-1 ring-white/10"
                          : "text-white/68"
                      }`}
                      href={link.href}
                    >
                      {link.text}
                    </a>
                  );
                })()
              }
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  // Toggle mobile menu
  const button = document.querySelector("#menu-button");
  const menu = document.querySelector("#main-menu");
  const navItems = document.querySelectorAll("#main-menu > ul > li > a");
  const sectionNavItems = Array.from(navItems).filter((item) =>
    item.getAttribute("href")?.startsWith("#"),
  );

  const toggleMenu = () => {
    menu?.classList.toggle("hidden");
    const isHidden = menu?.classList.contains("hidden");
    button?.setAttribute("aria-expanded", `${!isHidden}`);
  };

  button?.addEventListener("click", toggleMenu);
  navItems.forEach((item) => {
    item?.addEventListener("click", () => {
      if (window.innerWidth < 1024) toggleMenu();
    });
  });

  // Update navigation based on scroll position with Intersection Observer
  const observer =
    sectionNavItems.length > 0
      ? new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                sectionNavItems.forEach((item) => {
                  if (item.getAttribute("href") === `#${entry.target.id}`) {
                    item.classList.add("is-active", "bg-white/8", "text-white", "ring-1", "ring-white/10");
                  } else {
                    item.classList.remove("is-active", "bg-white/8", "text-white", "ring-1", "ring-white/10");
                  }
                });
              }
            });
          },
          { threshold: 0.5 },
        )
      : null;

  if (observer) {
    document.querySelectorAll("section").forEach((section) => {
      observer.observe(section);
    });
  }

  // Cleanup observer
  document.onvisibilitychange = () => {
    if (!observer) return;

    if (document.visibilityState === "hidden") {
      observer.disconnect();
    } else {
      document.querySelectorAll("section").forEach((section) => {
        observer.observe(section);
      });
    }
  };
</script>

<style>
  header {
    animation-timeline: scroll();
    animation-range: 0 650px;
  }

  @media (min-width: 1024px) {
    header {
      animation-timeline: auto;
      animation-range: normal;
    }
  }
</style>
